    {"name": "cdp_lldp_enabled",  "category": "network",       "description": "Enable (Yes) CDP (Cisco Discovery Protocol) and LLDP-MED for auto-discovery of VLAN and PoE settings from the network switch.", "example": "Yes", "default": "Yes"},
    {"name": "voice_vlan_id",     "category": "network",       "description": "802.1Q VLAN ID for voice traffic (1-4094). Set this if your network segregates voice and data VLANs.", "example": "100", "default": ""},
    {"name": "auto_answer",       "category": "call_features", "description": "Automatically answer incoming calls (Yes/No). Useful for intercom or paging systems.", "example": "Yes", "default": "No"},
    {"name": "dnd_enabled",       "category": "call_features", "description": "Enable Do Not Disturb by default (Yes/No). When on, the phone silently rejects all incoming calls.", "example": "No", "default": "No"},
    {"name": "call_waiting",      "category": "call_features", "description": "Enable call waiting to allow a second incoming call while already on a call (Yes/No).", "example": "Yes", "default": "Yes"},
    {"name": "cfw_always",        "category": "call_features", "description": "Call Forward Always - all calls are immediately forwarded to this number.", "example": "+61400000000", "default": ""},
    {"name": "cfw_busy",          "category": "call_features", "description": "Call Forward Busy - calls forward to this number when the line is busy.", "example": "voicemail", "default": ""},
    {"name": "cfw_no_answer",     "category": "call_features", "description": "Call Forward No Answer - calls forward to this number after the ring timeout.", "example": "voicemail", "default": ""},
    {"name": "dial_plan",         "category": "call_features", "description": "Cisco MPP dial plan string using TAPI-like pattern matching. Controls call routing and digit collection.", "example": "(9,8,**xx.|*xx.|[2-9]xxxxxx|1xxxxxxxxxx|xxxxxxxxxxxx)", "default": ""},
    {"name": "ntp_server",        "category": "provisioning",  "description": "Network Time Protocol server for automatic clock synchronization.", "example": "0.pool.ntp.org", "default": "0.pool.ntp.org"},
    {"name": "timezone",          "category": "provisioning",  "description": "Cisco timezone in GMT offset format. Examples: GMT+10:00 (AEST), GMT-05:00 (EST), GMT+05:30 (IST).", "example": "GMT+10:00", "default": "GMT-08:00"},
    {"name": "provisioning_url",  "category": "provisioning",  "description": "Base URL where the phone checks for configuration updates on boot.", "example": "http://192.168.1.1:8080", "default": ""},
    {"name": "firmware_url",      "category": "provisioning",  "description": "Full URL to Cisco firmware (.loads file) for automatic upgrades. Download firmware from software.cisco.com", "example": "http://192.168.1.1:8080/firmware/cisco.loads", "default": ""},
    {"name": "syslog_server",     "category": "diagnostics",   "description": "Remote syslog server IP for centralized logging and troubleshooting.", "example": "192.168.1.50", "default": ""},
    {"name": "debug_level",       "category": "diagnostics",   "description": "Syslog verbosity level: EMERGENCY, ALERT, CRITICAL, ERROR, WARNING, NOTICE, INFO, or DEBUG.", "example": "NOTICE", "default": "NOTICE"},
    {"name": "ringtone_url",      "category": "display",       "description": "HTTP URL to a custom ringtone WAV file. Must be 16-bit PCM, 8kHz mono, max 300KB.", "example": "http://192.168.1.1:8080/ringtones/MyRing.wav", "default": ""}
