    {"name": "outbound_proxy_host","category":"sip",            "description": "Outbound proxy or Session Border Controller (SBC) for NAT traversal. Leave blank if not required.", "example": "sbc.example.com", "default": ""},
    {"name": "backup_server",     "category": "sip",           "description": "Failover SIP registrar address used when the primary server is unreachable.", "example": "pbx2.example.com", "default": ""},
    {"name": "voicemail_number",  "category": "call_features", "description": "Voicemail access number for MWI (Message Waiting Indicator) and the messages button.", "example": "*97", "default": ""},
    {"name": "wallpaper_url",     "category": "display",       "description": "Full HTTP URL to a PNG/JPG background image. Cisco 88xx models use 800x480 resolution.", "example": "http://192.168.1.1:8080/media/logo.jpg", "default": ""},
    {"name": "screensaver_timeout","category":"display",        "description": "Minutes of inactivity before the screen saver activates. Set to 0 to disable.", "example": "10", "default": "0"},
    {"name": "admin_password",    "category": "security",      "description": "Administrator password for the phone's web interface. Leave blank to keep factory default.", "example": "Str0ngP@ss", "default": ""},
