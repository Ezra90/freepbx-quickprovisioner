    {"name": "sip_server",       "category": "sip",           "description": "Primary SIP registrar hostname or IP address where the phone registers.", "example": "pbx.example.com", "default": ""},
    {"name": "sip_port",         "category": "sip",           "description": "SIP signalling port (standard is 5060 for UDP/TCP, 5061 for TLS).", "example": "5060", "default": "5060"},
    {"name": "reg_expiry",       "category": "sip",           "description": "How often the phone re-registers with the SIP server (in seconds). Lower values detect outages faster.", "example": "3600", "default": "3600"},
    {"name": "outbound_proxy_host","category":"sip",           "description": "Outbound proxy or Session Border Controller (SBC) for NAT traversal. Leave blank if not required.", "example": "sbc.example.com", "default": ""},
    {"name": "outbound_proxy_port","category":"sip",           "description": "Port for the outbound proxy/SBC.", "example": "5060", "default": "5060"},
    {"name": "backup_server",    "category": "sip",           "description": "Failover SIP registrar address used when the primary server is unreachable.", "example": "pbx2.example.com", "default": ""},
    {"name": "voicemail_number", "category": "call_features", "description": "Voicemail access number for MWI (Message Waiting Indicator) and the voicemail button.", "example": "*97", "default": ""},
    {"name": "wallpaper_url",    "category": "display",       "description": "Full HTTP URL to a background image file. Must match your phone model's screen resolution.", "example": "http://192.168.1.1:8080/media/logo.jpg", "default": ""},
    {"name": "screensaver_timeout","category":"display",       "description": "Seconds of inactivity before the screensaver activates. Set to 0 to disable.", "example": "120", "default": "0"},
    {"name": "admin_password",   "category": "security",      "description": "Administrator password for the phone's web interface. Leave blank to keep factory default.", "example": "Str0ngP@ss", "default": ""},
    {"name": "web_ui_enabled",   "category": "security",      "description": "Enable (1) or disable (0) the phone's web management interface. Disabling improves security.", "example": "1", "default": "1"},
    {"name": "cdp_lldp_enabled", "category": "network",       "description": "Enable (1) CDP (Cisco Discovery Protocol) and LLDP (Link Layer Discovery Protocol) for auto-discovery of VLAN and PoE settings from the network switch.", "example": "1", "default": "1"},
    {"name": "auto_answer",      "category": "call_features", "description": "Enable (1) automatic call answering. Useful for intercom, paging systems, or hands-free operation.", "example": "1", "default": "0"},
    {"name": "dnd_enabled",      "category": "call_features", "description": "Enable (1) Do Not Disturb by default. When on, the phone silently rejects all incoming calls.", "example": "0", "default": "0"},
    {"name": "call_waiting",     "category": "call_features", "description": "Enable (1) call waiting to allow a second incoming call while already on a call.", "example": "1", "default": "1"},
    {"name": "cfw_always",       "category": "call_features", "description": "Call Forward Always - all calls are immediately forwarded to this number.", "example": "+61400000000", "default": ""},
    {"name": "cfw_busy",         "category": "call_features", "description": "Call Forward Busy - calls forward to this number when the line is busy.", "example": "voicemail", "default": ""},
    {"name": "cfw_no_answer",    "category": "call_features", "description": "Call Forward No Answer - calls forward to this number after the ring timeout.", "example": "voicemail", "default": ""},
    {"name": "dial_plan",        "category": "call_features", "description": "Polycom digitmap dial plan controlling call routing patterns. Uses regex-like syntax with T for timeout.", "example": "[2-9]11|0T|011xxx.T|[0-9]11|[0-9]{7,15}", "default": ""},
    {"name": "ntp_server",       "category": "provisioning",  "description": "Network Time Protocol server for automatic clock synchronization.", "example": "0.pool.ntp.org", "default": "0.pool.ntp.org"},
    {"name": "gmt_offset",       "category": "provisioning",  "description": "Timezone offset from GMT in seconds. e.g. AEST (+10hrs) = 36000, EST (-5hrs) = -18000.", "example": "36000", "default": "0"},
    {"name": "provisioning_url", "category": "provisioning",  "description": "Base URL where the phone checks for configuration updates on boot.", "example": "http://192.168.1.1:8080", "default": ""},
    {"name": "firmware_url",     "category": "provisioning",  "description": "Full URL to Polycom firmware (.sip.ld file) for automatic upgrades. Download firmware from support.polycom.com", "example": "http://192.168.1.1:8080/firmware/sip.ld", "default": ""},
    {"name": "syslog_server",    "category": "diagnostics",   "description": "Remote syslog server IP for centralized logging and troubleshooting.", "example": "192.168.1.50", "default": ""},
    {"name": "ringtone_url",     "category": "display",       "description": "HTTP URL to a custom ringtone WAV file. Must be 16-bit PCM, 8-16kHz mono.", "example": "http://192.168.1.1:8080/ringtones/MyRing.wav", "default": ""}
  ],
