    {"name": "backup_server",   "category": "sip",           "description": "Failover SIP registrar address used when the primary server is unreachable.", "example": "pbx2.example.com", "default": ""},
    {"name": "backup_port",     "category": "sip",           "description": "Port for the backup SIP server.", "example": "5060", "default": "5060"},
    {"name": "voicemail_number","category": "call_features",  "description": "Voicemail access number. Used for MWI (Message Waiting Indicator) subscription and voicemail button.", "example": "*97", "default": ""},
    {"name": "wallpaper_url",   "category": "display",       "description": "Full HTTP URL to a PNG/JPG background image. The image should match your phone's screen resolution.", "example": "http://192.168.1.1:8080/media/logo.jpg", "default": ""},
    {"name": "ring_type",       "category": "display",       "description": "Built-in ringtone name (Ring1.wav to Ring8.wav) or custom ringtone filename.", "example": "Ring1.wav", "default": "Ring1.wav"},
    {"name": "ringtone_url",    "category": "display",       "description": "HTTP URL to a custom ringtone WAV file. Must be 16-bit PCM, 8-16kHz sample rate.", "example": "http://192.168.1.1:8080/ringtones/custom.wav", "default": ""},
    {"name": "screensaver_timeout","category":"display",      "description": "Seconds of inactivity before the screensaver activates. Set to 0 to disable the screensaver.", "example": "120", "default": "0"},
    {"name": "admin_password",  "category": "security",      "description": "New administrator password for web UI and phone settings. Leave blank to keep factory default.", "example": "Str0ngP@ss", "default": ""},
    {"name": "web_ui_enabled",  "category": "security",      "description": "Enable (1) or disable (0) the phone's built-in web management interface. Disabling improves security.", "example": "1", "default": "1"},
    {"name": "voice_vlan_id",   "category": "network",       "description": "802.1Q VLAN ID for voice traffic (1-4094). Set this if your network segregates voice and data VLANs.", "example": "100", "default": ""},
    {"name": "data_vlan_id",    "category": "network",       "description": "802.1Q VLAN ID for the PC passthrough port. Only needed if PC traffic uses a different VLAN.", "example": "1", "default": ""},
    {"name": "cdp_lldp_enabled","category": "network",       "description": "Enable (1) CDP (Cisco Discovery Protocol) and LLDP (Link Layer Discovery Protocol). These protocols auto-discover VLAN tags and PoE settings from the network switch.", "example": "1", "default": "1"},
    {"name": "auto_answer",     "category": "call_features",  "description": "Enable (1) automatic call answering. Useful for intercom, paging systems, or hands-free operation.", "example": "1", "default": "0"},
    {"name": "dnd_enabled",     "category": "call_features",  "description": "Enable (1) Do Not Disturb by default. When on, the phone silently rejects all incoming calls.", "example": "0", "default": "0"},
    {"name": "call_waiting",    "category": "call_features",  "description": "Enable (1) call waiting to allow a second incoming call while already on a call.", "example": "1", "default": "1"},
    {"name": "cfw_always",      "category": "call_features",  "description": "Call Forward Always - all calls are immediately forwarded to this number.", "example": "+61400000000", "default": ""},
    {"name": "cfw_busy",        "category": "call_features",  "description": "Call Forward Busy - calls forward to this number when the line is busy.", "example": "voicemail", "default": ""},
    {"name": "cfw_no_answer",   "category": "call_features",  "description": "Call Forward No Answer - calls forward to this number after the ring timeout.", "example": "voicemail", "default": ""},
    {"name": "dial_plan",       "category": "call_features",  "description": "Yealink digitmap dial plan string controlling call routing patterns. Uses regex-like syntax.", "example": "(x+|\\+x+|xxx|xx+)", "default": ""},
    {"name": "ntp_server",      "category": "provisioning",  "description": "Network Time Protocol server for automatic clock synchronization.", "example": "0.pool.ntp.org", "default": "0.pool.ntp.org"},
    {"name": "timezone",        "category": "provisioning",  "description": "Timezone offset from UTC (e.g. +10 for AEST, -5 for EST).", "example": "+10", "default": "UTC"},
    {"name": "dst_enable",      "category": "provisioning",  "description": "Daylight Saving Time mode: 0=disabled, 1=automatic (recommended), 2=manual.", "example": "1", "default": "0"},
    {"name": "provisioning_url","category": "provisioning",  "description": "Base URL where the phone checks for configuration updates. Used for auto-provisioning on boot.", "example": "http://192.168.1.1:8080", "default": ""},
    {"name": "firmware_url",    "category": "provisioning",  "description": "Full URL to firmware .rom file for automatic upgrades. Yealink firmware files can be downloaded from support.yealink.com", "example": "http://192.168.1.1:8080/firmware/T54W.rom", "default": ""},
    {"name": "syslog_server",   "category": "diagnostics",   "description": "Remote syslog server IP for centralized logging and troubleshooting.", "example": "192.168.1.50", "default": ""},
    {"name": "debug_level",     "category": "diagnostics",   "description": "Syslog verbosity: 0=emergency only, 3=errors+warnings, 6=full debug. Higher values generate more logs.", "example": "3", "default": "0"}
  ],
