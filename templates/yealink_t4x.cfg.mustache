    {"name": "reg_expiry",      "category": "sip",           "description": "How often the phone re-registers with the SIP server (in seconds). Lower values detect outages faster but increase traffic.", "example": "3600", "default": "3600"},
    {"name": "outbound_proxy_host","category":"sip",          "description": "Outbound proxy or Session Border Controller (SBC) for NAT traversal. Leave blank if not using a proxy.", "example": "sbc.example.com", "default": ""},
